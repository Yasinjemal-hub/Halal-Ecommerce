# Root .env.example - Copy to .env and fill in values
# DO NOT COMMIT .env FILES

# ─── Backend Configuration ─────────────────────────────────
# These are typically set in backend/.env or Render dashboard

# Server
# PORT=5000
# NODE_ENV=development

# Database (MongoDB Atlas)
# MONGO_ATLAS_URI=mongodb+srv://username:password@cluster.mongodb.net/halal-ecommerce?retryWrites=true&w=majority

# JWT Secrets (generate with: openssl rand -base64 48)
# JWT_SECRET=your-super-secret-jwt-access-token-key-min-32-chars
# JWT_REFRESH_SECRET=your-super-secret-jwt-refresh-token-key-min-32-chars
# JWT_EXPIRES_IN=15m
# JWT_REFRESH_EXPIRES_IN=7d
# ACCESS_TOKEN_MAX_AGE_MS=900000

# Client URL (for CORS and email links)
# CLIENT_URL=http://localhost:3000
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Email (Gmail SMTP with App Password)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your_email@gmail.com
# EMAIL_PASS=your_gmail_app_password
# EMAIL_FROM="Halal E-Commerce <your_email@gmail.com>"

# Optional: Payment & Uploads
# STRIPE_API_KEY=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# ─── Frontend Configuration ────────────────────────────────
# These are typically set in frontend/.env or Vercel dashboard

# Backend API URL
# REACT_APP_API_URL=http://localhost:5000/api

# Optional Features
# REACT_APP_ENABLE_ANALYTICS=false
# REACT_APP_GA_MEASUREMENT_ID=