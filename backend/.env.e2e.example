# E2E test environment variables
# Copy this file to .env.e2e and update values as needed.
NODE_ENV=e2e
PORT=5000
MONGO_URI=mongodb://localhost:27017/halal-ecommerce-e2e
JWT_SECRET=your-e2e-jwt-secret-key-at-least-32-chars
JWT_REFRESH_SECRET=your-e2e-refresh-secret-key-at-least-32
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d
CLIENT_URL=http://localhost:3000
